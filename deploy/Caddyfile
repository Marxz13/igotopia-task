# Reverse proxy in front of the app. SITE_ADDRESS comes from
# docker-compose.prod.yml: ':80' locally, or a domain on the VM (Caddy then
# handles HTTPS automatically).
# The health check makes Caddy route to the app only once /api/health is 200
# (Postgres + Redis up) - same gate the deploy uses.
{$SITE_ADDRESS} {
	reverse_proxy app:3000 {
		health_uri /api/health
		health_interval 10s
		health_timeout 5s
	}

	encode gzip
	log
}
