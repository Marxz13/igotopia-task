# Copy to .env.local (Next) / .env (worker) and fill in. Never commit real secrets.

# Postgres connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lead_discovery

# Redis connection string
REDIS_URL=redis://localhost:6379

# Session cookie signing secret (generate a long random value)
SESSION_SECRET=change-me-in-local-env

# Provider mode: mock | real
PROVIDER_MODE=mock

# Frontend: use the MSW mock instead of real API routes.
NEXT_PUBLIC_USE_MOCKS=false
