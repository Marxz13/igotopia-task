# Copy to .env.local (Next) / .env (worker) and fill in. Never commit real secrets.

# Postgres connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lead_discovery

# Redis connection string
REDIS_URL=redis://localhost:6379

# Host ports the compose services publish (override if 5432/6379 are taken).
# Keep DATABASE_URL/REDIS_URL in sync with any change.
POSTGRES_PORT=5432
REDIS_PORT=6379

# Session cookie signing secret (generate a long random value)
SESSION_SECRET=change-me-in-local-env

# Provider mode: mock | real
PROVIDER_MODE=mock

# Worker: concurrent jobs per stage
WORKER_CONCURRENCY=5

# Artificial pause per stage (ms) so discover/verify are watchable and cancellable.
# 0 = no delay. Tests force 0 regardless of this value.
STAGE_DELAY_MS=2000

# Crash hook: the discover stage exits right after inserting leads (restart-safe
# proof). Accepts 0 | 1 | true | false; leave 0 in normal runs.
CRASH_AFTER_DISCOVER=0

# Frontend: use the MSW mock instead of real API routes.
NEXT_PUBLIC_USE_MOCKS=false
