{
  "name": "lead-discovery-pipeline",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant lead discovery pipeline: async discover -> verify job pipeline with an org-scoped inbox.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx scripts/worker.ts",
    "seed": "tsx scripts/seed.ts",
    "db:generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run --passWithNoTests",
    "test:ui": "vitest run tests/ui",
    "test:be": "vitest run tests/state-machine.test.ts tests/providers.test.ts tests/api-search.test.ts tests/worker-pipeline.test.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "bullmq": "^5.79.2",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "next": "^15.1.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.6",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
